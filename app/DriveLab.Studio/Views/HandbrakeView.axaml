<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:conv="using:DriveLab.Studio.Converters"
             xmlns:controls="using:DriveLab.Studio.Controls"
             xmlns:loc="using:DriveLab.Studio.Localization"
             x:Class="DriveLab.Studio.Views.HandbrakeView"
             x:DataType="vm:HandbrakeViewModel">
    <UserControl.Resources>
        <conv:IntEqualsConverter x:Key="IntEquals" />
    </UserControl.Resources>

    <Border Classes="card">
        <Grid RowDefinitions="Auto,*">
            <!-- Cabeçalho: o título do módulo vive no topo do app ("DriveLab Studio — Freio de mão").
                 Aqui só perfil (esq) + ações (dir), alinhados entre si. -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left"
                            IsEnabled="{Binding IsConnected}">
                    <TextBlock Text="{loc:Translate Profile_Label}" Classes="muted" VerticalAlignment="Center" />
                    <ComboBox MinWidth="170" ItemsSource="{Binding ProfileLibrary.Profiles}" SelectedItem="{Binding ProfileLibrary.SelectedName}"
                              PlaceholderText="{loc:Translate Profile_Placeholder}" />
                    <Button Classes="accent" Content="{loc:Translate Profile_Save}" Command="{Binding ProfileLibrary.SaveCommand}" />
                    <TextBox Width="150" Text="{Binding ProfileLibrary.NewName}" Watermark="{loc:Translate Profile_NameWatermark}" />
                    <Button Content="{loc:Translate Profile_SaveAs}" Command="{Binding ProfileLibrary.SaveAsCommand}" />
                    <Button Content="{loc:Translate Profile_Rename}" Command="{Binding ProfileLibrary.RenameCommand}" />
                    <Button Content="{loc:Translate Profile_Delete}" Command="{Binding ProfileLibrary.DeleteCommand}" />
                    <!-- Compartilhar perfis: exporta (selecionado ou todos) e importa sem sobrescrever -->
                    <Button Content="{loc:Translate Profile_Export}" Command="{Binding ProfileLibrary.ExportCommand}"
                            IsVisible="{Binding ProfileLibrary.CanExchangeFiles}" />
                    <Button Content="{loc:Translate Profile_Import}" Command="{Binding ProfileLibrary.ImportCommand}"
                            IsVisible="{Binding ProfileLibrary.CanExchangeFiles}" />
                </StackPanel>

                <!-- Ações à direita, no topo (Calibrar/Padrão/Salvar no controlador). -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Border Classes="statusBadge" IsVisible="{Binding IsConnected}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource DlAccent}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SourceLabel}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource DlText}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Button Content="{loc:Translate Connect}" Command="{Binding ConnectCommand}" IsVisible="{Binding IsSimulator}" />
                    <Button Content="{loc:Translate Disconnect}" Command="{Binding DisconnectCommand}" IsVisible="{Binding IsSimulator}" />
                    <Button Content="{loc:Translate Pedal_Calibrate}" Command="{Binding OpenCalibrationCommand}" />
                    <Button Content="{loc:Translate Default}" Command="{Binding LoadDefaultsCommand}" />
                    <Button Classes="accent" Content="{loc:Translate SaveToController}" Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <!-- Eixo único: uma coluna de config no mesmo estilo das colunas dos pedais -->
                <Border Classes="card" HorizontalAlignment="Left" MaxWidth="520" Margin="6,6,6,6">
                    <StackPanel Spacing="8">

                        <!-- Curva + deadzone -->
                        <TextBlock Text="{loc:Translate Handbrake_Curve}" Classes="muted" />
                        <controls:PedalCurveEditor Height="200"
                            Points="{Binding Points}"
                            DeadzoneLow="{Binding DeadzoneLow, Mode=TwoWay}"
                            DeadzoneHigh="{Binding DeadzoneHigh, Mode=TwoWay}"
                            LiveInput01="{Binding CurrentInput01}"
                            LiveOutput01="{Binding CurrentOutput01}"
                            EditEnabled="{Binding CanEdit}" />

                        <!-- Inverter -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Classes="fieldLabel" Text="{loc:Translate Handbrake_Invert}" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding Invert}" IsEnabled="{Binding CanEdit}"
                                          OnContent="" OffContent="" />
                        </Grid>

                        <!-- Suavização: título + valor na mesma linha; slider abaixo (padrão "Range do batente"). -->
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Classes="fieldLabel" Text="{loc:Translate Handbrake_Smooth}" />
                                <Border Grid.Column="1" Classes="valueBox">
                                    <TextBlock Text="{Binding Smooth, StringFormat={}{0:0}}" />
                                </Border>
                            </Grid>
                            <Slider Minimum="0" Maximum="100" Value="{Binding Smooth}" IsEnabled="{Binding CanEdit}"
                                    VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Tipo de sensor (chips, como nos pedais) -->
                        <TextBlock Classes="muted" Text="{loc:Translate Handbrake_Sensor}" />
                        <UniformGrid Rows="1" IsEnabled="{Binding CanEdit}">
                            <Button Classes="chip" Content="Pot" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,3,0"
                                    Command="{Binding SelectSensorCommand}" CommandParameter="0"
                                    Classes.selected="{Binding SensorType, Converter={StaticResource IntEquals}, ConverterParameter=0}" />
                            <Button Classes="chip" Content="Hall" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="3,0"
                                    Command="{Binding SelectSensorCommand}" CommandParameter="1"
                                    Classes.selected="{Binding SensorType, Converter={StaticResource IntEquals}, ConverterParameter=1}" />
                            <Button Classes="chip" Content="Load cell" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="3,0,0,0"
                                    Command="{Binding SelectSensorCommand}" CommandParameter="2"
                                    Classes.selected="{Binding SensorType, Converter={StaticResource IntEquals}, ConverterParameter=2}" />
                        </UniformGrid>

                        <!-- Botão digital: habilita + limiar (configuração, não indicador ao vivo) -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Classes="fieldLabel" Text="{loc:Translate Handbrake_ButtonEnabled}" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ButtonEnabled}" IsEnabled="{Binding CanEdit}"
                                          OnContent="" OffContent="" />
                        </Grid>
                        <!-- Limiar do botão: título + valor na mesma linha; slider abaixo (padrão "Range do batente"). -->
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Classes="fieldLabel" Text="{loc:Translate Handbrake_ButtonThreshold}" />
                                <Border Grid.Column="1" Classes="valueBox">
                                    <TextBlock Text="{Binding ButtonThreshold, StringFormat={}{0:0}%}" />
                                </Border>
                            </Grid>
                            <Slider Minimum="0" Maximum="100" Value="{Binding ButtonThreshold}"
                                    IsEnabled="{Binding ButtonEnabled}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Min/max calibrado -->
                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Grid.Column="0" Classes="endLabel" HorizontalAlignment="Center"
                                       Text="{Binding InputMin, StringFormat='min {0}'}" />
                            <TextBlock Grid.Column="1" Classes="endLabel" HorizontalAlignment="Center"
                                       Text="{Binding InputMax, StringFormat='max {0}'}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Overlay de calibração: raw ao vivo do eixo único (mesmo padrão dos pedais) -->
            <Border IsVisible="{Binding IsCalibrating}" Background="#CC000000">
                <Border Classes="card" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="460">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Translate Pedal_Calibration}" Classes="h2" />
                        <Grid ColumnDefinitions="110,*,56,120" Margin="0,4">
                            <TextBlock Grid.Column="0" Text="{loc:Translate Handbrake_Title}" Classes="fieldLabel" VerticalAlignment="Center" />
                            <Grid Grid.Column="1" x:Name="track" Margin="8,0">
                                <ProgressBar Minimum="0" Maximum="4095" Value="{Binding RawLive}" VerticalAlignment="Center" />
                                <!-- Bolinha no máximo atingido na calibração -->
                                <Ellipse Width="12" Height="12" Fill="White"
                                         Stroke="{DynamicResource DlAccent}" StrokeThickness="2"
                                         HorizontalAlignment="Left" VerticalAlignment="Center"
                                         IsVisible="{Binding Capturing}">
                                    <Ellipse.Margin>
                                        <MultiBinding Converter="{x:Static conv:CalMarkerMarginConverter.Instance}">
                                            <Binding Path="CalMax" />
                                            <Binding Path="#track.Bounds.Width" />
                                        </MultiBinding>
                                    </Ellipse.Margin>
                                </Ellipse>
                            </Grid>
                            <TextBlock Grid.Column="2" Text="{Binding RawLive}" Classes="endLabel" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding CalRange}" Classes="endLabel"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       IsVisible="{Binding Capturing}" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Content="{loc:Translate Start}" Command="{Binding StartCalibrationCommand}" />
                            <Button Classes="accent" Content="{loc:Translate Finish}" Command="{Binding FinishCalibrationCommand}" />
                            <Button Content="{loc:Translate Close}" Command="{Binding CloseCalibrationCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
