<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:loc="using:DriveLab.Studio.Localization"
             x:Class="DriveLab.Studio.Views.AutoProfileView"
             x:DataType="vm:AutoProfileViewModel">
    <Border Classes="card">
        <Grid RowDefinitions="Auto,Auto,*">
            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Text="{loc:Translate AutoProfile_Title}" Classes="h2" />
                <TextBlock Text="{loc:Translate AutoProfile_Desc}" Classes="muted" TextWrapping="Wrap" MaxWidth="720" HorizontalAlignment="Left" />
                <CheckBox IsChecked="{Binding Enabled}" Content="{loc:Translate AutoProfile_Enable}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{loc:Translate AutoProfile_CurrentGame}" Classes="muted" VerticalAlignment="Center" />
                    <Border Classes="valueBox"><TextBlock Text="{Binding CurrentGame}" /></Border>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1" ColumnDefinitions="170,*,*,*,*" Margin="0,16,0,4">
                <TextBlock Grid.Column="0" Text="{loc:Translate AutoProfile_Game}" Classes="muted" />
                <TextBlock Grid.Column="1" Text="{loc:Translate Nav_WheelBase}" Classes="muted" Margin="2,0" />
                <TextBlock Grid.Column="2" Text="{loc:Translate Nav_Wheel}" Classes="muted" Margin="2,0" />
                <TextBlock Grid.Column="3" Text="{loc:Translate Nav_Pedals}" Classes="muted" Margin="2,0" />
                <TextBlock Grid.Column="4" Text="{loc:Translate Nav_Handbrake}" Classes="muted" Margin="2,0" />
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GameBindingViewModel">
                            <Grid ColumnDefinitions="170,*,*,*,*" Margin="0,3">
                                <TextBlock Grid.Column="0" Text="{Binding GameName}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" Margin="2,0" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding BaseProfiles}" SelectedItem="{Binding BaseProfile}" />
                                <ComboBox Grid.Column="2" Margin="2,0" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding WheelProfiles}" SelectedItem="{Binding WheelProfile}" />
                                <ComboBox Grid.Column="3" Margin="2,0" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding PedalsProfiles}" SelectedItem="{Binding PedalsProfile}" />
                                <ComboBox Grid.Column="4" Margin="2,0" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding HandbrakeProfiles}" SelectedItem="{Binding HandbrakeProfile}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
