<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:DriveLab.Studio.Views"
        xmlns:vm="using:DriveLab.Studio.ViewModels"
        xmlns:loc="using:DriveLab.Studio.Localization"
        x:Class="DriveLab.Studio.Views.TestWindow"
        x:DataType="vm:TestViewModel"
        Width="500" Height="380"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="{loc:Translate Test_Title}"
        Background="{DynamicResource DlBackground}">
    <views:TestView Margin="20" />
</Window>
