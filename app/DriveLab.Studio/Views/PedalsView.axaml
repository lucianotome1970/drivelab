<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:conv="using:DriveLab.Studio.Converters"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="DriveLab.Studio.Views.PedalsView"
             x:DataType="vm:PedalsViewModel">
    <UserControl.Resources>
        <conv:IntEqualsConverter x:Key="IntEquals" />

        <DataTemplate x:Key="PedalColumn" x:DataType="vm:PedalColumnViewModel">
          <Grid ColumnDefinitions="*,Auto" Margin="6">
            <Border Grid.Column="0" Classes="card" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Label}" Classes="h2" HorizontalAlignment="Center" />

                    <!-- Curvas de saída (chips estilo Pit House) -->
                    <TextBlock Text="Curvas de saída" Classes="muted" />
                    <ItemsControl ItemsSource="{Binding PresetOptions}" IsEnabled="{Binding CanEdit}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PedalPresetOption">
                                <Button Classes="chip" Content="{Binding Name}"
                                        Classes.selected="{Binding IsSelected}"
                                        Command="{Binding $parent[ItemsControl].((vm:PedalColumnViewModel)DataContext).SelectPresetCommand}"
                                        CommandParameter="{Binding Preset}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Margin="3,8,3,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <lvc:CartesianChart Series="{Binding CurveSeries}" Height="200" />

                    <!-- Pontos da curva (label · slider laranja · valueBox) -->
                    <ItemsControl ItemsSource="{Binding Points}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PedalCurvePointViewModel">
                                <Grid ColumnDefinitions="44,*,Auto" Margin="0,2">
                                    <TextBlock Grid.Column="0" Classes="endLabel" Text="{Binding Label}" />
                                    <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Value}"
                                            IsSnapToTickEnabled="True" TickFrequency="1"
                                            VerticalAlignment="Center" Margin="8,0"
                                            IsEnabled="{Binding $parent[ItemsControl].((vm:PedalColumnViewModel)DataContext).CanEdit}" />
                                    <Border Grid.Column="2" Classes="valueBox" MinWidth="46" Padding="8,3">
                                        <TextBlock Text="{Binding Value, StringFormat={}{0:0}}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Inverter (toggle laranja) -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="fieldLabel" Text="Inverter" />
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding Invert}" IsEnabled="{Binding CanEdit}"
                                      OnContent="" OffContent="" />
                    </Grid>

                    <!-- Suavização -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Classes="fieldLabel" Text="Suavização" Margin="0,0,10,0" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Smooth}" IsEnabled="{Binding CanEdit}"
                                VerticalAlignment="Center" />
                        <Border Grid.Column="2" Classes="valueBox" MinWidth="46" Padding="8,3">
                            <TextBlock Text="{Binding Smooth, StringFormat={}{0:0}}" />
                        </Border>
                    </Grid>

                    <!-- Sensor (chips) -->
                    <TextBlock Classes="muted" Text="Sensor" />
                    <UniformGrid Rows="1" IsEnabled="{Binding CanEdit}">
                        <Button Classes="chip" Content="Pot" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,3,0"
                                Command="{Binding SelectSensorCommand}" CommandParameter="0"
                                Classes.selected="{Binding SensorType, Converter={StaticResource IntEquals}, ConverterParameter=0}" />
                        <Button Classes="chip" Content="Hall" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="3,0"
                                Command="{Binding SelectSensorCommand}" CommandParameter="1"
                                Classes.selected="{Binding SensorType, Converter={StaticResource IntEquals}, ConverterParameter=1}" />
                        <Button Classes="chip" Content="Load cell" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="3,0,0,0"
                                Command="{Binding SelectSensorCommand}" CommandParameter="2"
                                Classes.selected="{Binding SensorType, Converter={StaticResource IntEquals}, ConverterParameter=2}" />
                    </UniformGrid>

                    <!-- Calibração -->
                    <Button Classes="accent" Command="{Binding CalibrateCommand}" IsEnabled="{Binding CanEdit}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Content="{Binding CalibrateLabel}" />
                    <Grid ColumnDefinitions="*,*">
                        <TextBlock Grid.Column="0" Classes="endLabel" HorizontalAlignment="Center"
                                   Text="{Binding InputMin, StringFormat='min {0}'}" />
                        <TextBlock Grid.Column="1" Classes="endLabel" HorizontalAlignment="Center"
                                   Text="{Binding InputMax, StringFormat='max {0}'}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Barra de progressão vertical (avanço do pedal ao vivo) -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto" Width="34" Margin="10,10,0,10">
                <ProgressBar Grid.Row="0" Orientation="Vertical" Minimum="0" Maximum="100"
                             Value="{Binding CurrentOutputPercent}"
                             VerticalAlignment="Stretch" HorizontalAlignment="Center" Width="12" />
                <TextBlock Grid.Row="1" Text="{Binding CurrentOutputPercent, StringFormat={}{0:0}%}"
                           Classes="endLabel" HorizontalAlignment="Center" Margin="0,6,0,0" />
            </Grid>
          </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Classes="card">
        <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBlock Grid.Column="0" Text="Pedais" Classes="h2" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Conectar" Command="{Binding ConnectCommand}" />
                    <Button Content="Desconectar" Command="{Binding DisconnectCommand}" />
                    <Button Content="Carregar" Command="{Binding LoadPreferencesCommand}" />
                    <Button Content="Salvar" Command="{Binding SavePreferencesCommand}" />
                    <Button Classes="accent" Content="Salvar no controlador" Command="{Binding SaveToControllerCommand}" />
                </StackPanel>
            </Grid>

            <TabControl>
                <TabItem Header="Pedais">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Columns}" ItemTemplate="{StaticResource PedalColumn}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Monitor de entrada">
                    <lvc:CartesianChart Series="{Binding CombinedSeries}" />
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</UserControl>
