<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:conv="using:DriveLab.Studio.Converters"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="DriveLab.Studio.Views.PedalsView"
             x:DataType="vm:PedalsViewModel">
    <UserControl.Resources>
        <conv:DoubleToDecimalConverter x:Key="DoubleToDecimal" />
        <DataTemplate x:Key="PedalColumn" x:DataType="vm:PedalColumnViewModel">
            <Border Classes="card" Margin="6" Width="250">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Label}" Classes="h2" HorizontalAlignment="Center" />

                    <lvc:CartesianChart Series="{Binding CurveSeries}" Height="180" />

                    <ItemsControl ItemsSource="{Binding Points}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PedalCurvePointViewModel">
                                <Grid ColumnDefinitions="48,*" Margin="0,3">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource DlMuted}" />
                                    <NumericUpDown Grid.Column="1" Minimum="0" Maximum="100" Increment="1"
                                                   Value="{Binding Value, Converter={StaticResource DoubleToDecimal}}"
                                                   IsEnabled="{Binding $parent[ItemsControl].((vm:PedalColumnViewModel)DataContext).CanEdit}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <CheckBox Content="Inverter" IsChecked="{Binding Invert}" IsEnabled="{Binding CanEdit}" />

                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Suavização" VerticalAlignment="Center" Foreground="{DynamicResource DlMuted}" />
                        <Slider Width="120" Minimum="0" Maximum="100" Value="{Binding Smooth}" IsEnabled="{Binding CanEdit}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Sensor" VerticalAlignment="Center" Foreground="{DynamicResource DlMuted}" />
                        <ComboBox SelectedIndex="{Binding SensorType}" IsEnabled="{Binding CanEdit}">
                            <ComboBoxItem>Potenciômetro</ComboBoxItem>
                            <ComboBoxItem>Hall</ComboBoxItem>
                            <ComboBoxItem>Load cell</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <Button Content="Calibrar" Command="{Binding CalibrateCommand}" IsEnabled="{Binding CanEdit}"
                            Classes.selected="{Binding IsCalibrating}" HorizontalAlignment="Stretch" />
                    <TextBlock HorizontalAlignment="Center" Foreground="{DynamicResource DlMuted}"
                               Text="{Binding InputMin, StringFormat='min {0}'}" />
                    <TextBlock HorizontalAlignment="Center" Foreground="{DynamicResource DlMuted}"
                               Text="{Binding InputMax, StringFormat='max {0}'}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Classes="card">
        <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBlock Grid.Column="0" Text="Pedais" Classes="h2" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <ComboBox ItemsSource="{Binding Presets}" IsEnabled="{Binding IsConnected}"
                              PlaceholderText="Preset de curva">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PedalCurvePreset">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Conectar" Command="{Binding ConnectCommand}" />
                    <Button Content="Desconectar" Command="{Binding DisconnectCommand}" />
                    <Button Content="Carregar" Command="{Binding LoadPreferencesCommand}" />
                    <Button Content="Salvar" Command="{Binding SavePreferencesCommand}" />
                    <Button Content="Salvar no controlador" Command="{Binding SaveToControllerCommand}" />
                </StackPanel>
            </Grid>
            <Border DockPanel.Dock="Bottom" Height="140" Margin="0,12,0,0">
                <lvc:CartesianChart Series="{Binding CombinedSeries}" />
            </Border>
            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Columns}" ItemTemplate="{StaticResource PedalColumn}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
