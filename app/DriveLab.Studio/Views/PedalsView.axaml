<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:conv="using:DriveLab.Studio.Converters"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="DriveLab.Studio.Views.PedalsView"
             x:DataType="vm:PedalsViewModel">
    <UserControl.Resources>
        <conv:DoubleToDecimalConverter x:Key="DoubleToDecimal" />
        <DataTemplate x:Key="PedalColumn" x:DataType="vm:PedalColumnViewModel">
            <Border Classes="card" Margin="8" HorizontalAlignment="Stretch">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding Label}" Classes="h2" HorizontalAlignment="Center" />

                    <TextBlock Text="Curvas de saída" Foreground="{DynamicResource DlMuted}" />
                    <!-- Preset de curva por pedal (chips estilo Pit House) -->
                    <ItemsControl ItemsSource="{Binding PresetOptions}" IsEnabled="{Binding CanEdit}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PedalPresetOption">
                                <Button Classes="chip" Content="{Binding Name}"
                                        Classes.selected="{Binding IsSelected}"
                                        Command="{Binding $parent[ItemsControl].((vm:PedalColumnViewModel)DataContext).SelectPresetCommand}"
                                        CommandParameter="{Binding Preset}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <lvc:CartesianChart Series="{Binding CurveSeries}" Height="200" />

                    <ItemsControl ItemsSource="{Binding Points}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PedalCurvePointViewModel">
                                <Grid ColumnDefinitions="56,*" Margin="0,3">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource DlMuted}" />
                                    <NumericUpDown Grid.Column="1" Minimum="0" Maximum="100" Increment="1"
                                                   Value="{Binding Value, Converter={StaticResource DoubleToDecimal}}"
                                                   IsEnabled="{Binding $parent[ItemsControl].((vm:PedalColumnViewModel)DataContext).CanEdit}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Inverter" VerticalAlignment="Center"
                                   Foreground="{DynamicResource DlMuted}" />
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding Invert}" IsEnabled="{Binding CanEdit}"
                                      OnContent="" OffContent="" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="Suavização" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource DlMuted}" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Smooth}" IsEnabled="{Binding CanEdit}" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="Sensor" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource DlMuted}" />
                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                  SelectedIndex="{Binding SensorType}" IsEnabled="{Binding CanEdit}">
                            <ComboBoxItem>Potenciômetro</ComboBoxItem>
                            <ComboBoxItem>Hall</ComboBoxItem>
                            <ComboBoxItem>Load cell</ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <Button Classes="accent" Command="{Binding CalibrateCommand}" IsEnabled="{Binding CanEdit}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Content="{Binding CalibrateLabel}" />
                    <Grid ColumnDefinitions="*,*">
                        <TextBlock Grid.Column="0" HorizontalAlignment="Center" Foreground="{DynamicResource DlMuted}"
                                   Text="{Binding InputMin, StringFormat='min {0}'}" />
                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" Foreground="{DynamicResource DlMuted}"
                                   Text="{Binding InputMax, StringFormat='max {0}'}" />
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Classes="card">
        <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBlock Grid.Column="0" Text="Pedais" Classes="h2" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Conectar" Command="{Binding ConnectCommand}" />
                    <Button Content="Desconectar" Command="{Binding DisconnectCommand}" />
                    <Button Content="Carregar" Command="{Binding LoadPreferencesCommand}" />
                    <Button Content="Salvar" Command="{Binding SavePreferencesCommand}" />
                    <Button Content="Salvar no controlador" Command="{Binding SaveToControllerCommand}" />
                </StackPanel>
            </Grid>
            <Border DockPanel.Dock="Bottom" Height="150" Margin="0,12,0,0">
                <lvc:CartesianChart Series="{Binding CombinedSeries}" />
            </Border>
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Columns}" ItemTemplate="{StaticResource PedalColumn}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
