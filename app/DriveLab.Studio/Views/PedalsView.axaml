<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:conv="using:DriveLab.Studio.Converters"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:controls="using:DriveLab.Studio.Controls"
             xmlns:loc="using:DriveLab.Studio.Localization"
             x:Class="DriveLab.Studio.Views.PedalsView"
             x:DataType="vm:PedalsViewModel">
    <UserControl.Resources>
        <conv:IntEqualsConverter x:Key="IntEquals" />

        <DataTemplate x:Key="PedalColumn" x:DataType="vm:PedalColumnViewModel">
          <Grid ColumnDefinitions="*,Auto" Margin="6">
            <Border Grid.Column="0" Classes="card" HorizontalAlignment="Stretch">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Label}" Classes="h2" HorizontalAlignment="Center" />

                    <!-- Curvas de saída (chips estilo Pit House) -->
                    <TextBlock Text="{loc:Translate Pedal_OutputCurves}" Classes="muted" />
                    <ItemsControl ItemsSource="{Binding PresetOptions}" IsEnabled="{Binding CanEdit}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PedalPresetOption">
                                <Button Classes="chip" Content="{Binding Name}"
                                        Classes.selected="{Binding IsSelected}"
                                        Command="{Binding $parent[ItemsControl].((vm:PedalColumnViewModel)DataContext).SelectPresetCommand}"
                                        CommandParameter="{Binding Preset}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Margin="3,8,3,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <controls:PedalCurveEditor Height="200"
                        Points="{Binding Points}"
                        DeadzoneLow="{Binding DeadzoneLow, Mode=TwoWay}"
                        DeadzoneHigh="{Binding DeadzoneHigh, Mode=TwoWay}"
                        LiveInput01="{Binding CurrentInput01}"
                        LiveOutput01="{Binding CurrentOutput01}"
                        EditEnabled="{Binding CanEdit}" />
                    <TextBlock Text="{loc:Translate Pedal_PreviewOnly}" Classes="endLabel"
                               HorizontalAlignment="Center" IsVisible="{Binding CurvePreviewOnly}" />

                    <!-- Inverter (toggle laranja) -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="fieldLabel" Text="{loc:Translate Pedal_Invert}" />
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding Invert}" IsEnabled="{Binding CanEdit}"
                                      OnContent="" OffContent="" />
                    </Grid>

                    <!-- Suavização -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Classes="fieldLabel" Text="{loc:Translate Pedal_Smoothing}" Margin="0,0,10,0" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Smooth}" IsEnabled="{Binding CanEdit}"
                                VerticalAlignment="Center" />
                        <Border Grid.Column="2" Classes="valueBox" MinWidth="46" Padding="8,3">
                            <TextBlock Text="{Binding Smooth, StringFormat={}{0:0}}" />
                        </Border>
                    </Grid>

                    <!-- Freio: força em % / KG + fundo de escala -->
                    <StackPanel IsVisible="{Binding IsBrake}" Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Classes="fieldLabel" Text="{Binding BrakeReadout}" />
                            <Border Grid.Column="1" Classes="valueBox" IsVisible="{Binding ForceMaxed}"
                                    Background="{DynamicResource DlAccent}">
                                <TextBlock Text="Force 100%" Foreground="#111111" />
                            </Border>
                        </Grid>
                        <UniformGrid Rows="1">
                            <Button Classes="chip" Content="%" Command="{Binding SetBrakeUnitCommand}" CommandParameter="pct"
                                    Classes.selected="{Binding !BrakeUnitKg}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,3,0" />
                            <Button Classes="chip" Content="KG" Command="{Binding SetBrakeUnitCommand}" CommandParameter="kg"
                                    Classes.selected="{Binding BrakeUnitKg}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="3,0,0,0" />
                        </UniformGrid>
                        <UniformGrid Rows="1">
                            <Button Classes="chip" Content="50kg" Command="{Binding SetLoadCellMaxCommand}" CommandParameter="50"
                                    Classes.selected="{Binding LoadCellMaxKg, Converter={StaticResource IntEquals}, ConverterParameter=50}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,2,0" />
                            <Button Classes="chip" Content="80kg" Command="{Binding SetLoadCellMaxCommand}" CommandParameter="80"
                                    Classes.selected="{Binding LoadCellMaxKg, Converter={StaticResource IntEquals}, ConverterParameter=80}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0" />
                            <Button Classes="chip" Content="100kg" Command="{Binding SetLoadCellMaxCommand}" CommandParameter="100"
                                    Classes.selected="{Binding LoadCellMaxKg, Converter={StaticResource IntEquals}, ConverterParameter=100}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0" />
                            <Button Classes="chip" Content="120kg" Command="{Binding SetLoadCellMaxCommand}" CommandParameter="120"
                                    Classes.selected="{Binding LoadCellMaxKg, Converter={StaticResource IntEquals}, ConverterParameter=120}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0,0,0" />
                        </UniformGrid>
                    </StackPanel>

                    <!-- Sensor (chips) -->
                    <TextBlock Classes="muted" Text="{loc:Translate Pedal_Sensor}" IsVisible="{Binding ShowSensor}" />
                    <UniformGrid Rows="1" IsEnabled="{Binding CanEdit}" IsVisible="{Binding ShowSensor}">
                        <Button Classes="chip" Content="Pot" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,3,0"
                                Command="{Binding SelectSensorCommand}" CommandParameter="0"
                                Classes.selected="{Binding SensorType, Converter={StaticResource IntEquals}, ConverterParameter=0}" />
                        <Button Classes="chip" Content="Hall" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="3,0"
                                Command="{Binding SelectSensorCommand}" CommandParameter="1"
                                Classes.selected="{Binding SensorType, Converter={StaticResource IntEquals}, ConverterParameter=1}" />
                        <Button Classes="chip" Content="Load cell" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="3,0,0,0"
                                Command="{Binding SelectSensorCommand}" CommandParameter="2"
                                Classes.selected="{Binding SensorType, Converter={StaticResource IntEquals}, ConverterParameter=2}" />
                    </UniformGrid>

                    <!-- Min/max calibrado (a calibração agora é o modal único no topo) -->
                    <Grid ColumnDefinitions="*,*">
                        <TextBlock Grid.Column="0" Classes="endLabel" HorizontalAlignment="Center"
                                   Text="{Binding InputMin, StringFormat='min {0}'}" />
                        <TextBlock Grid.Column="1" Classes="endLabel" HorizontalAlignment="Center"
                                   Text="{Binding InputMax, StringFormat='max {0}'}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Barra de progressão vertical (avanço do pedal ao vivo) -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto" Width="34" Margin="10,10,0,10">
                <ProgressBar Grid.Row="0" Orientation="Vertical" Minimum="0" Maximum="100"
                             Value="{Binding CurrentOutputPercent}"
                             VerticalAlignment="Stretch" HorizontalAlignment="Center" Width="12" />
                <TextBlock Grid.Row="1" Text="{Binding CurrentOutputPercent, StringFormat={}{0:0}%}"
                           Classes="endLabel" HorizontalAlignment="Center" Margin="0,6,0,0" />
            </Grid>
          </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Classes="card">
        <Grid>
            <!-- Sem título: as abas ocupam o topo (a 1ª aba já é "Pedais") -->
            <TabControl>
                <TabItem Header="{loc:Translate Tab_Pedals}">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Columns}" ItemTemplate="{StaticResource PedalColumn}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="{loc:Translate Tab_InputMonitor}">
                    <lvc:CartesianChart Series="{Binding CombinedSeries}" />
                </TabItem>
            </TabControl>

            <!-- Ações sobrepostas à direita da faixa de abas -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="8" Margin="0,2,0,0">
                <TextBlock Text="{Binding SourceLabel}" Classes="muted" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Button Content="{loc:Translate Connect}" Command="{Binding ConnectCommand}" />
                <Button Content="{loc:Translate Disconnect}" Command="{Binding DisconnectCommand}" />
                <Button Content="{loc:Translate Pedal_Calibrate}" Command="{Binding OpenCalibrationCommand}" />
                <Button Content="{loc:Translate Load}" Command="{Binding LoadPreferencesCommand}" />
                <Button Content="{loc:Translate Save}" Command="{Binding SavePreferencesCommand}" />
                <Button Classes="accent" Content="{loc:Translate SaveToController}" Command="{Binding SaveToControllerCommand}"
                        IsEnabled="{Binding CanSaveToController}" />
            </StackPanel>

            <!-- Overlay de calibração: raw ao vivo dos 3 pedais -->
            <Border IsVisible="{Binding IsCalibrating}" Background="#CC000000">
                <Border Classes="card" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="460">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Translate Pedal_Calibration}" Classes="h2" />
                        <ItemsControl ItemsSource="{Binding Columns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PedalColumnViewModel">
                                    <Grid ColumnDefinitions="120,*,64" Margin="0,4">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Classes="fieldLabel" VerticalAlignment="Center" />
                                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="4095" Value="{Binding RawLive}" Margin="8,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding RawLive}" Classes="endLabel" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Content="{loc:Translate Start}" Command="{Binding StartCalibrationCommand}" />
                            <Button Classes="accent" Content="{loc:Translate Finish}" Command="{Binding FinishCalibrationCommand}" />
                            <Button Content="{loc:Translate Close}" Command="{Binding CloseCalibrationCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
