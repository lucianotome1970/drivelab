<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             x:Class="DriveLab.Studio.Views.SettingsGroupView"
             x:DataType="vm:SettingsGroupViewModel">
    <UserControl.Resources>
        <DataTemplate x:Key="FieldBlock" x:DataType="vm:SettingFieldViewModel">
            <StackPanel Spacing="7" Margin="0,10">
                <!-- Label + caixa de valor -->
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Classes="fieldLabel" Text="{Binding DisplayName}" />
                    <Border Grid.Column="1" Classes="valueBox">
                        <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ValueText}" />
                            <TextBlock Text="{Binding Unit}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Mín · slider · Máx -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Classes="endLabel" Text="{Binding Min, StringFormat={}{0:0}}" Margin="0,0,10,0" />
                    <Slider Grid.Column="1" Minimum="{Binding Min}" Maximum="{Binding Max}" Value="{Binding Value}"
                            IsEnabled="{Binding IsConnected}" IsSnapToTickEnabled="{Binding IsInteger}"
                            TickFrequency="1" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Classes="endLabel" Text="{Binding Max, StringFormat={}{0:0}}" Margin="10,0,0,0" />
                </Grid>

                <!-- Chips de preset -->
                <ItemsControl ItemsSource="{Binding PresetOptions}" IsVisible="{Binding HasPresets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- Rows=1 espalha os chips igualmente pela largura da barra -->
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PresetOptionViewModel">
                            <Button Classes="chip" Content="{Binding Value}"
                                    Classes.selected="{Binding IsSelected}"
                                    Command="{Binding SelectCommand}"
                                    HorizontalAlignment="Center" Margin="3,8,3,0"
                                    HorizontalContentAlignment="Center" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid ColumnDefinitions="*,28,*" Margin="4,4,20,4">
            <ItemsControl Grid.Column="0" ItemsSource="{Binding LeftColumn}" ItemTemplate="{StaticResource FieldBlock}" />
            <ItemsControl Grid.Column="2" ItemsSource="{Binding RightColumn}" ItemTemplate="{StaticResource FieldBlock}" />
        </Grid>
    </ScrollViewer>
</UserControl>
