============================================================================ -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:conv="using:DriveLab.Studio.Converters"
             xmlns:loc="using:DriveLab.Studio.Localization"
             x:Class="DriveLab.Studio.Views.WheelView"
             x:DataType="vm:WheelViewModel">
    <UserControl.Styles>
        <!-- Marcador de LED: apagado = esmaecido; aceso (IsPressed) = cor cheia + destaque -->
        <Style Selector="Border.led">
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
        </Style>
        <Style Selector="Border.led.pressed">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="scale(1.35)" />
        </Style>
        <Style Selector="Border.led.selected">
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <!-- Pá (aparece pelo recorte transparente do desenho): SEMPRE visível em cinza escuro
             (para se ver as pás conforme a contagem); ao ser acionada, clareia (highlight). -->
        <Style Selector="Rectangle.paddle">
            <Setter Property="Fill" Value="#3B424D" />
        </Style>
        <Style Selector="Rectangle.paddle.active">
            <Setter Property="Fill" Value="#7A828F" />
        </Style>
    </UserControl.Styles>

    <Border Classes="card">
        <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Spacing="16" Margin="6,40,6,6">
                    <TextBlock Text="{loc:Translate Wheel_Config}" Classes="h2" />

                    <!-- Duas colunas: volante+cores à esquerda, pás à direita -->
                    <Grid ColumnDefinitions="Auto,28,Auto" HorizontalAlignment="Left">

                        <!-- Coluna esquerda: desenho do volante + cores dos botões -->
                        <StackPanel Grid.Column="0" Spacing="12" Width="480">
                            <TextBlock Text="{loc:Translate Wheel_Leds}" Classes="muted" />
                            <Grid Width="480" Height="480" HorizontalAlignment="Center">
                                <!-- Pás ATRÁS do desenho (z-order antes da imagem): aparecem pelos cutouts que você
                                     deixou transparentes no wheel-config.png; acendem (accent) quando ativas. Ajustáveis. -->
                                <Canvas Width="480" Height="480" IsHitTestVisible="False">
                                    <!-- Cada retângulo cobre o recorte; a forma visível vem do recorte transparente. -->
                                    <Rectangle Classes="paddle" Classes.active="{Binding ShiftDown.IsPressed}"
                                               Canvas.Left="64" Canvas.Top="172" Width="44" Height="48" />
                                    <Rectangle Classes="paddle" Classes.active="{Binding ShiftUp.IsPressed}"
                                               Canvas.Left="376" Canvas.Top="172" Width="44" Height="48" />
                                    <Rectangle Classes="paddle" Classes.active="{Binding ClutchLeft.IsPressed}"
                                               Canvas.Left="66" Canvas.Top="257" Width="40" Height="26"
                                               IsVisible="{Binding ShowBottomPair}" />
                                    <Rectangle Classes="paddle" Classes.active="{Binding ClutchRight.IsPressed}"
                                               Canvas.Left="378" Canvas.Top="257" Width="40" Height="26"
                                               IsVisible="{Binding ShowBottomPair}" />
                                </Canvas>
                                <Image Source="avares://DriveLab.Studio/Assets/wheel-config.png" Stretch="Uniform" />
                                <ItemsControl ItemsSource="{Binding Buttons}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><Canvas Width="480" Height="480" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.Styles>
                                        <Style Selector="ContentPresenter" x:DataType="vm:WheelButtonViewModel">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WheelButtonViewModel">
                                            <Border Classes="led"
                                                    Classes.pressed="{Binding IsPressed}"
                                                    Classes.selected="{Binding IsSelected}"
                                                    Width="{Binding Diameter}" Height="{Binding Diameter}" CornerRadius="999"
                                                    Background="{Binding ColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"
                                                    ToolTip.Tip="{Binding Name}"
                                                    PointerPressed="OnMarkerPressed" PointerReleased="OnControlReleased" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Knobs rotativos (potência): anel que acende ao girar (Glow via telemetria). -->
                                <ItemsControl ItemsSource="{Binding Knobs}" IsHitTestVisible="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><Canvas Width="480" Height="480" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.Styles>
                                        <Style Selector="ContentPresenter" x:DataType="vm:WheelButtonViewModel">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WheelButtonViewModel">
                                            <Border Width="{Binding Diameter}" Height="{Binding Diameter}" CornerRadius="999"
                                                    BorderBrush="{DynamicResource DlAccent}" BorderThickness="3"
                                                    Background="Transparent" Opacity="{Binding Glow}"
                                                    ToolTip.Tip="{Binding Name}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- Paleta de cores (aplica no botão selecionado). Só com o aro conectado:
                                 a cor vai AO VIVO ao dispositivo. -->
                            <TextBlock Text="{Binding SelectedButton.Name, FallbackValue=''}" Classes="muted" />
                            <TextBlock Text="{loc:Translate Wheel_ConnectToEditColors}" Classes="muted"
                                       IsVisible="{Binding !IsConnected}" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding Palette}" IsEnabled="{Binding IsConnected}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Button Width="32" Height="32" CornerRadius="16" Margin="4" Padding="0"
                                                Background="{Binding Converter={x:Static conv:HexToBrushConverter.Instance}}"
                                                BorderBrush="{DynamicResource DlBorder}" BorderThickness="1"
                                                Command="{Binding $parent[ItemsControl].((vm:WheelViewModel)DataContext).SetColorCommand}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Coluna direita: configuração das pás -->
                        <StackPanel Grid.Column="2" Spacing="10" Width="360" VerticalAlignment="Top">
                            <TextBlock Text="{loc:Translate Wheel_Paddles}" Classes="h2" />
                            <TextBlock Text="{loc:Translate Wheel_PaddleCount}" Classes="muted" />
                            <UniformGrid Rows="1" MaxWidth="200" HorizontalAlignment="Left">
                                <Button Classes="chip" Content="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,3,0"
                                        Command="{Binding SetPaddleCountCommand}" CommandParameter="2"
                                        Classes.selected="{Binding PaddleCount, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter=2}" />
                                <Button Classes="chip" Content="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="3,0,0,0"
                                        Command="{Binding SetPaddleCountCommand}" CommandParameter="4"
                                        Classes.selected="{Binding PaddleCount, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter=4}" />
                            </UniformGrid>

                            <!-- As pás (indicador ativo/inativo) agora ficam SOBRE o desenho do volante,
                                 atrás dos punhos. Aqui no painel fica só a configuração. -->

                            <!-- Config do par de baixo (só quando 4 pás) -->
                            <StackPanel Spacing="10" IsVisible="{Binding ShowBottomPair}">
                                <StackPanel Spacing="10" DataContext="{Binding BottomPair}"
                                            x:DataType="vm:PaddlePairViewModel">
                                    <TextBlock Text="{loc:Translate Wheel_Function}" Classes="muted" />
                                    <UniformGrid Rows="1">
                                        <Button Classes="chip" Content="{loc:Translate Wheel_Clutch}" Margin="0,0,3,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Command="{Binding SetFunctionCommand}" CommandParameter="Clutch"
                                                Classes.selected="{Binding Function, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter=Clutch}" />
                                        <Button Classes="chip" Content="{loc:Translate Wheel_Free}" Margin="3,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Command="{Binding SetFunctionCommand}" CommandParameter="Free"
                                                Classes.selected="{Binding Function, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter=Free}" />
                                        <Button Classes="chip" Content="{loc:Translate Wheel_Button}" Margin="3,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Command="{Binding SetFunctionCommand}" CommandParameter="Button"
                                                Classes.selected="{Binding Function, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter=Button}" />
                                    </UniformGrid>

                                    <StackPanel Spacing="10" IsVisible="{Binding ShowMode}">
                                        <TextBlock Text="{loc:Translate Wheel_Mode}" Classes="muted" />
                                        <UniformGrid Rows="1">
                                            <Button Classes="chip" Content="{loc:Translate Wheel_Combined}" Margin="0,0,3,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding SetModeCommand}" CommandParameter="Combined"
                                                    Classes.selected="{Binding Mode, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter=Combined}" />
                                            <Button Classes="chip" Content="{loc:Translate Wheel_Independent}" Margin="3,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                    Command="{Binding SetModeCommand}" CommandParameter="Independent"
                                                    Classes.selected="{Binding Mode, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter=Independent}" />
                                        </UniformGrid>
                                    </StackPanel>

                                    <TextBlock Text="{loc:Translate Wheel_Actuation}" Classes="muted" />
                                    <UniformGrid Rows="1">
                                        <Button Classes="chip" Content="{loc:Translate Wheel_Digital}" Margin="0,0,3,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Command="{Binding SetActuationCommand}" CommandParameter="Digital"
                                                Classes.selected="{Binding Actuation, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter=Digital}" />
                                        <Button Classes="chip" Content="{loc:Translate Wheel_Progression}" Margin="3,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Command="{Binding SetActuationCommand}" CommandParameter="Progression"
                                                Classes.selected="{Binding Actuation, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter=Progression}" />
                                    </UniformGrid>

                                    <StackPanel Spacing="6" IsVisible="{Binding ShowBitePoint}">
                                        <TextBlock Text="{loc:Translate Wheel_BitePoint}" Classes="muted" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Slider Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding BitePoint}" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Classes="valueBox" MinWidth="46" Padding="8,3">
                                                <TextBlock Text="{Binding BitePoint, StringFormat={}{0:0}%}" />
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Ações no topo à direita (mesmo padrão de pedais/freio de mão) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="8" Margin="0,2,0,0">
                <!-- Conectar/Desconectar só no simulador; no real a conexão é automática (hotplug USB). -->
                <Button Content="{loc:Translate Connect}" Command="{Binding ConnectCommand}" IsVisible="{Binding IsSimulator}" />
                <Button Content="{loc:Translate Disconnect}" Command="{Binding DisconnectCommand}" IsVisible="{Binding IsSimulator}" />
                <Border Classes="statusBadge" IsVisible="{Binding IsConnected}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource DlAccent}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SourceLabel}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource DlText}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Button Content="{loc:Translate Load}" Command="{Binding LoadCommand}" />
                <Button Content="{loc:Translate Save}" Command="{Binding SaveCommand}" />
                <!-- Habilitado só quando há alteração não salva (dirty) e o aro está conectado. -->
                <Button Classes="accent" Content="{loc:Translate SaveToController}" Command="{Binding SaveToControllerCommand}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
