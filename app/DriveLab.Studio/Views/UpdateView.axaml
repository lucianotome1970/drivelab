<!-- ============================================================================
     DriveLab
     UpdateView.axaml — Tela de atualização de firmware por USB: escolher
     dispositivo, selecionar arquivo, validar e enviar (EnterDfu → aguardar
     bootloader → flash via dfu-util), com barra de progresso e status.
     Autor: Luciano Tomé <lucianotome1970@gmail.com>
     Copyright (c) 2026 Luciano Tomé — Licença MIT
============================================================================ -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:loc="using:DriveLab.Studio.Localization"
             xmlns:update="using:DriveLab.Core.Update"
             x:Class="DriveLab.Studio.Views.UpdateView"
             x:DataType="vm:UpdateViewModel">
    <Border Classes="card">
        <StackPanel Spacing="16" MaxWidth="560" HorizontalAlignment="Left">
            <!-- Cabeçalho: o título do módulo vive no topo do app ("DriveLab Studio — Atualizar firmware"). -->
            <TextBlock Text="{loc:Translate Update_Title}" Classes="h2" />

            <!-- Placa detectada + versão do firmware que está rodando nela -->
            <Border Classes="statusBadge" HorizontalAlignment="Left">
                <TextBlock Text="{Binding ConnectedDeviceInfo}" TextWrapping="Wrap" MaxWidth="480" />
            </Border>

            <!-- Dispositivo -->
            <StackPanel Spacing="6">
                <TextBlock Text="{loc:Translate Update_Device}" Classes="muted" />
                <ComboBox MinWidth="220" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                          IsEnabled="{Binding !IsSending}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="update:IDeviceUpdater">
                            <TextBlock Text="{Binding Kind}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Verificar atualizações no GitHub -->
            <StackPanel Spacing="6" IsVisible="{Binding CanCheckUpdates}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="{loc:Translate Update_Check}" Command="{Binding CheckUpdatesCommand}"
                            IsEnabled="{Binding !IsSending}" />
                    <TextBlock Text="{Binding UpdateCheckMessage}" Classes="muted" VerticalAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="420" IsVisible="{Binding HasUpdateCheckMessage}" />
                </StackPanel>
            </StackPanel>

            <!-- Arquivo -->
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="{loc:Translate Update_SelectFile}" Command="{Binding SelectFileCommand}"
                            IsEnabled="{Binding !IsSending}" />
                    <TextBlock Text="{Binding FirmwarePath}" Classes="muted" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" MaxWidth="320"
                               IsVisible="{Binding HasFirmwarePath}" />
                    <TextBlock Text="{loc:Translate Update_NoFileSelected}" Classes="muted" VerticalAlignment="Center"
                               IsVisible="{Binding !HasFirmwarePath}" />
                </StackPanel>
                <TextBlock Text="{Binding ValidationMessage}" TextWrapping="Wrap"
                           IsVisible="{Binding HasValidationMessage}" />
            </StackPanel>

            <!-- Enviar -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="accent" Content="{loc:Translate Update_Send}" Command="{Binding SendCommand}" />
            </StackPanel>

            <!-- Progresso -->
            <StackPanel Spacing="6" IsVisible="{Binding IsSending}">
                <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress}" />
                <TextBlock Text="{Binding Progress, StringFormat={}{0:P0}}" Classes="muted" />
            </StackPanel>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                       IsVisible="{Binding HasStatusMessage}" />

            <!-- Fallback manual: a placa não entrou em DFU sozinha → SW1→DFU + power-cycle → Continuar -->
            <Border Classes="statusBadge" HorizontalAlignment="Left" IsVisible="{Binding NeedsManualDfu}">
                <StackPanel Spacing="10" MaxWidth="480">
                    <TextBlock TextWrapping="Wrap" FontWeight="SemiBold"
                               Text="Modo de atualização manual" />
                    <TextBlock TextWrapping="Wrap"
                               Text="1) Coloque a chave SW1 da placa em DFU.&#10;2) Faça um power-cycle (RESET ou tire/recoloque a energia).&#10;3) Clique em Continuar." />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="accent" Content="Continuar" Command="{Binding ContinueDfuCommand}" />
                        <Button Content="Cancelar" Command="{Binding CancelDfuCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Aviso -->
            <Border Classes="statusBadge" HorizontalAlignment="Left">
                <TextBlock Text="{loc:Translate Update_Warning}" TextWrapping="Wrap" MaxWidth="480" />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
