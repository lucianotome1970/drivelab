<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:views="using:DriveLab.Studio.Views"
             x:Class="DriveLab.Studio.Views.HomeView"
             x:DataType="vm:HomeViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Auto">
        <!-- Colunas iguais + linha Auto: os dois cards esticam para a mesma altura -->
        <Grid ColumnDefinitions="420,16,420" RowDefinitions="Auto" HorizontalAlignment="Left" Margin="0,0,0,16">
            <!-- Card do volante -->
            <views:DashboardView Grid.Column="0" DataContext="{Binding Wheel}" />

            <!-- Card resumo dos pedais (ao vivo) — mesmo tamanho do card do volante -->
            <Border Grid.Column="2" Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Pedais" Classes="h2" />
                    <Image Source="avares://DriveLab.Studio/Assets/pedais-dlab.png" Width="360" Stretch="Uniform"
                           HorizontalAlignment="Center" />
                    <ItemsControl ItemsSource="{Binding Pedals.Columns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PedalColumnViewModel">
                                <StackPanel Spacing="6" Margin="0,6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{DynamicResource DlText}" />
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentOutput01, StringFormat={}{0:P0}}" Foreground="{DynamicResource DlMuted}" />
                                    </Grid>
                                    <ProgressBar Minimum="0" Maximum="1" Value="{Binding CurrentOutput01}"
                                                 Height="8" CornerRadius="4" Foreground="#FF6A00" Background="#22FFFFFF" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
