<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             x:Class="DriveLab.Studio.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <Border Classes="card" HorizontalAlignment="Left" VerticalAlignment="Top" Width="420">
        <StackPanel Spacing="16">
            <TextBlock Text="Volante (ODESC)" Classes="h2" />

            <!-- Área de calibração: desenho de volante que gira com o ângulo lido -->
            <Grid Width="240" Height="240" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <RotateTransform Angle="{Binding AngleDegrees}" />
                </Grid.RenderTransform>
                <!-- Aro -->
                <Ellipse Width="212" Height="212" Stroke="{DynamicResource DlMuted}" StrokeThickness="16"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                <!-- Raio horizontal (3 e 9 horas) -->
                <Rectangle Width="156" Height="16" Fill="{DynamicResource DlMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                <!-- Raio inferior (6 horas) -->
                <Rectangle Width="16" Height="60" Fill="{DynamicResource DlMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,22" />
                <!-- Cubo central -->
                <Ellipse Width="64" Height="64" Fill="{DynamicResource DlCard}" Stroke="{DynamicResource DlBorder}"
                         StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Ellipse Width="18" Height="18" Fill="{DynamicResource DlAccent}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                <!-- Marcador central (listra laranja no topo do aro, como no volante real) -->
                <Border Width="30" Height="16" Background="{DynamicResource DlAccent}" CornerRadius="4"
                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0" />
            </Grid>

            <!-- Leitura de ângulo (não gira) -->
            <TextBlock Text="{Binding AngleDegrees, StringFormat={}{0:0}°}"
                       Foreground="{DynamicResource DlText}" FontSize="26" FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <!-- Presets (explicit buttons — robust, no item-template command binding) -->
            <TextBlock Text="Ângulo máximo" Classes="muted" />
            <WrapPanel>
                <Button Classes="chip" Content="360"  Command="{Binding SetMaxAngleCommand}" CommandParameter="360" />
                <Button Classes="chip" Content="540"  Command="{Binding SetMaxAngleCommand}" CommandParameter="540" />
                <Button Classes="chip" Content="720"  Command="{Binding SetMaxAngleCommand}" CommandParameter="720" />
                <Button Classes="chip" Content="900"  Command="{Binding SetMaxAngleCommand}" CommandParameter="900" />
                <Button Classes="chip" Content="1080" Command="{Binding SetMaxAngleCommand}" CommandParameter="1080" />
                <Button Classes="chip" Content="1440" Command="{Binding SetMaxAngleCommand}" CommandParameter="1440" />
                <Button Classes="chip" Content="1800" Command="{Binding SetMaxAngleCommand}" CommandParameter="1800" />
            </WrapPanel>

            <Button Classes="accent" Content="Center" Command="{Binding CenterCommand}" HorizontalAlignment="Left" />
        </StackPanel>
    </Border>
</UserControl>
