<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:conv="using:DriveLab.Studio.Converters"
             xmlns:loc="using:DriveLab.Studio.Localization"
             x:Class="DriveLab.Studio.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <UserControl.Resources>
        <conv:IntEqualsConverter x:Key="IntEquals" />
    </UserControl.Resources>
    <Border Classes="card" Classes.connected="{Binding IsConnected}">
        <StackPanel Spacing="16">
            <TextBlock Text="{loc:Translate Wheel_Title}" Classes="h2" />

            <!-- Área de calibração: imagem do volante DriveLab girando com o ângulo lido -->
            <Grid Width="240" Height="240" HorizontalAlignment="Center" ClipToBounds="False">
                <Image Source="avares://DriveLab.Studio/Assets/wheel.png" Width="220" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="50%,50%">
                    <Image.RenderTransform>
                        <RotateTransform Angle="{Binding AngleDegrees}" />
                    </Image.RenderTransform>
                </Image>
            </Grid>

            <!-- Leitura de ângulo (não gira) -->
            <TextBlock Text="{Binding AngleDegrees, StringFormat={}{0:0}°}"
                       Foreground="{DynamicResource DlText}" FontSize="26" FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <!-- Presets (explicit buttons — robust, no item-template command binding) -->
            <TextBlock Text="{loc:Translate Wheel_MaxAngle}" Classes="muted" />
            <WrapPanel>
                <Button Classes="chip" Content="360"  Command="{Binding SetMaxAngleCommand}" CommandParameter="360"  Classes.selected="{Binding MotionRange, Converter={StaticResource IntEquals}, ConverterParameter=360}" />
                <Button Classes="chip" Content="540"  Command="{Binding SetMaxAngleCommand}" CommandParameter="540"  Classes.selected="{Binding MotionRange, Converter={StaticResource IntEquals}, ConverterParameter=540}" />
                <Button Classes="chip" Content="720"  Command="{Binding SetMaxAngleCommand}" CommandParameter="720"  Classes.selected="{Binding MotionRange, Converter={StaticResource IntEquals}, ConverterParameter=720}" />
                <Button Classes="chip" Content="900"  Command="{Binding SetMaxAngleCommand}" CommandParameter="900"  Classes.selected="{Binding MotionRange, Converter={StaticResource IntEquals}, ConverterParameter=900}" />
                <Button Classes="chip" Content="1080" Command="{Binding SetMaxAngleCommand}" CommandParameter="1080" Classes.selected="{Binding MotionRange, Converter={StaticResource IntEquals}, ConverterParameter=1080}" />
                <Button Classes="chip" Content="1440" Command="{Binding SetMaxAngleCommand}" CommandParameter="1440" Classes.selected="{Binding MotionRange, Converter={StaticResource IntEquals}, ConverterParameter=1440}" />
            </WrapPanel>

            <Button Classes="accent" Content="{loc:Translate Center}" Command="{Binding CenterCommand}" HorizontalAlignment="Left" />
        </StackPanel>
    </Border>
</UserControl>
