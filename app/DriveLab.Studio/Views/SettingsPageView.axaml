<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:loc="using:DriveLab.Studio.Localization"
             x:Class="DriveLab.Studio.Views.SettingsPageView"
             x:DataType="vm:SettingsPageViewModel">
    <Border Classes="card">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" Classes="h2" Margin="0,0,0,12" />

            <!-- Barra inferior (estilo MOZA) -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                        Spacing="10" Margin="0,14,0,0">
                <Button Content="{loc:Translate Default}" Command="{Binding ResetDefaultsCommand}" />
                <Button Classes="accent" Content="{loc:Translate Save}" Command="{Binding SaveCommand}" />
            </StackPanel>

            <TabControl ItemsSource="{Binding Tabs}">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PageTab">
                        <TextBlock Text="{Binding Header}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:PageTab">
                        <!-- ViewLocator renderiza o conteúdo da aba (settings ou gráfico) -->
                        <ContentControl Content="{Binding Content}" />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </DockPanel>
    </Border>
</UserControl>
