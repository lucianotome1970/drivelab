<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:loc="using:DriveLab.Studio.Localization"
             x:Class="DriveLab.Studio.Views.SettingsPageView"
             x:DataType="vm:SettingsPageViewModel">
    <Border Classes="card">
        <Grid RowDefinitions="Auto,*">
            <!-- Cabeçalho: título à esquerda, ações no topo à direita (mesmo padrão de pedais/freio/volante). -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Content="{loc:Translate Default}" Command="{Binding ResetDefaultsCommand}" />
                    <!-- Grava na flash da base (BaseCommand.SaveSettings); habilitado só com alteração não salva. -->
                    <Button Classes="accent" Content="{loc:Translate SaveToController}" Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1" ItemsSource="{Binding Tabs}">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PageTab">
                        <TextBlock Text="{Binding Header}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:PageTab">
                        <!-- ViewLocator renderiza o conteúdo da aba (settings ou gráfico) -->
                        <ContentControl Content="{Binding Content}" />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
