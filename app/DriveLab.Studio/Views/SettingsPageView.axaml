<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DriveLab.Studio.ViewModels"
             xmlns:loc="using:DriveLab.Studio.Localization"
             x:Class="DriveLab.Studio.Views.SettingsPageView"
             x:DataType="vm:SettingsPageViewModel">
    <Border Classes="card">
        <Grid RowDefinitions="Auto,Auto,*">
            <!-- Cabeçalho: título à esquerda, ações no topo à direita (mesmo padrão de pedais/freio/volante). -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="h2" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Content="{loc:Translate Default}" Command="{Binding ResetDefaultsCommand}" />
                    <!-- Grava na flash da base (BaseCommand.SaveSettings); habilitado só com alteração não salva. -->
                    <Button Classes="accent" Content="{loc:Translate SaveToController}" Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>

            <!-- Perfis nomeados. Habilitado só com a base conectada (aplicar escreve no controlador). -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12" HorizontalAlignment="Left"
                        IsEnabled="{Binding IsConnected}">
                <TextBlock Text="{loc:Translate Profile_Label}" Classes="muted" VerticalAlignment="Center" />
                <ComboBox MinWidth="170" ItemsSource="{Binding ProfileLibrary.Profiles}" SelectedItem="{Binding ProfileLibrary.SelectedName}"
                          PlaceholderText="{loc:Translate Profile_Placeholder}" />
                <Button Classes="accent" Content="{loc:Translate Profile_Save}" Command="{Binding ProfileLibrary.SaveCommand}" />
                <TextBox Width="150" Text="{Binding ProfileLibrary.NewName}" Watermark="{loc:Translate Profile_NameWatermark}" />
                <Button Content="{loc:Translate Profile_SaveAs}" Command="{Binding ProfileLibrary.SaveAsCommand}" />
                <Button Content="{loc:Translate Profile_Rename}" Command="{Binding ProfileLibrary.RenameCommand}" />
                <Button Content="{loc:Translate Profile_Delete}" Command="{Binding ProfileLibrary.DeleteCommand}" />
            </StackPanel>

            <TabControl Grid.Row="2" ItemsSource="{Binding Tabs}">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PageTab">
                        <TextBlock Text="{Binding Header}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:PageTab">
                        <!-- ViewLocator renderiza o conteúdo da aba (settings ou gráfico) -->
                        <ContentControl Content="{Binding Content}" />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
